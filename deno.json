{
	"name": "@danet/grpc",
	"version": "0.1.0",
	"license": "MIT",
	"exports": {
		".": "./mod.ts"
	},
	"lint": {
		"include": [
			"src/"
		],
		"exclude": [
			"node_modules/",
			"./**/*.test.ts"
		]
	},
	"fmt": {
		"options": {
			"singleQuote": true,
			"useTabs": true
		},
		"exclude": [
			"./node_modules/"
		]
	},
	"compilerOptions": {
		"emitDecoratorMetadata": true,
		"experimentalDecorators": true
	},
	"nodeModulesDir": "auto",
	"tasks": {
		"test": "NO_LOG=true deno test -A --no-check spec/**/*.test.ts"
	},
	"imports": {
		"@danet/grpc": "./mod.ts",
		"@danet/core": "jsr:@danet/core@^2.11.0",
		"@danet/core/metadata": "jsr:@danet/core@^2.11.0/metadata",
		"@grpc/grpc-js": "npm:@grpc/grpc-js@1.12.5",
		"@grpc/proto-loader": "npm:@grpc/proto-loader@0.7.13",
		"@std/assert": "jsr:@std/assert@1.0.3"
	}
}
